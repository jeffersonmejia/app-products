<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Productos App</title>
    <script type="importmap"></script>
    <script>
        tailwind = {
            config: {
                corePlugins: {
                    preflight: false
                }
            }
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CrudProductos.styles.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white shadow-sm">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm">
            <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-2 sm:px-6 lg:px-8">
                <a class="text-base font-semibold tracking-normal text-slate-950 no-underline hover:text-slate-700" asp-area="" asp-controller="Productos" asp-action="Index">Productos App</a>
                <button class="navbar-toggler rounded-md border border-slate-300 px-2 py-1 text-sm" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse sm:!flex sm:justify-end">
                    <ul class="navbar-nav mt-2 flex gap-1 sm:mt-0 sm:flex-row sm:items-center">
                        <li>
                            <a class="block rounded-md px-2.5 py-1.5 text-sm font-medium text-slate-600 no-underline hover:bg-slate-100 hover:text-slate-950" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li>
                            <a class="block rounded-md px-2.5 py-1.5 text-sm font-medium text-slate-600 no-underline hover:bg-slate-100 hover:text-slate-950" asp-area="" asp-controller="Productos" asp-action="Index">Productos</a>
                        </li>
                        <li>
                            <a class="block rounded-md px-2.5 py-1.5 text-sm font-medium text-slate-600 no-underline hover:bg-slate-100 hover:text-slate-950" asp-area="" asp-controller="Categorias" asp-action="Index">Nueva tabla: Categorias</a>
                        </li>
                        <li>
                            <a class="block rounded-md px-2.5 py-1.5 text-sm font-medium text-slate-600 no-underline hover:bg-slate-100 hover:text-slate-950" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t border-slate-200 bg-white">
        <div class="mx-auto max-w-7xl px-4 py-5 text-sm text-slate-500 sm:px-6 lg:px-8">
            &copy; 2026 - Productos App - <a class="text-slate-600 underline underline-offset-4 hover:text-slate-950" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
