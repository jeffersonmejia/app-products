@model CrudProductos.Models.PagedResult<CrudProductos.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
        <h1 class="mb-1 text-2xl font-semibold text-slate-950">Productos</h1>
        <p class="m-0 text-sm text-slate-500">
            Mostrando @Model.Items.Count de @Model.TotalItems productos. Pagina @Model.Page de @Model.TotalPages.
        </p>
    </div>

    <a class="inline-flex items-center justify-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white no-underline shadow-sm hover:bg-slate-700" asp-action="Create">Crear producto</a>
</div>

<div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-100">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">
                Nombre
                    </th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">
                Descripcion
                    </th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">
                Precio
                    </th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">
                Stock
                    </th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">
                FechaRegistro
                    </th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
@foreach (var item in Model.Items) {
                <tr class="hover:bg-slate-50">
                    <td class="px-4 py-3 text-sm font-medium text-slate-900">
                @Html.DisplayFor(modelItem => item.Nombre)
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-600">
                @Html.DisplayFor(modelItem => item.Descripcion)
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-700">
                @Html.DisplayFor(modelItem => item.Precio)
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-700">
                @Html.DisplayFor(modelItem => item.Stock)
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-500">
                @Html.DisplayFor(modelItem => item.FechaRegistro)
                    </td>
                    <td class="whitespace-nowrap px-4 py-3 text-right text-sm">
                        <a class="font-medium text-slate-700 no-underline hover:text-slate-950" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                        <span class="mx-1 text-slate-300">|</span>
                        <a class="font-medium text-slate-700 no-underline hover:text-slate-950" asp-action="Details" asp-route-id="@item.Id">Detalle</a>
                        <span class="mx-1 text-slate-300">|</span>
                        <a class="font-medium text-red-600 no-underline hover:text-red-800" asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>
</div>

<nav class="mt-6 flex flex-wrap items-center gap-2" aria-label="Paginacion de productos">
    <a class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium no-underline @(Model.HasPreviousPage ? "bg-white text-slate-700 hover:bg-slate-100" : "pointer-events-none bg-slate-100 text-slate-400")" asp-action="Index" asp-route-page="@(Model.Page - 1)">Anterior</a>

    @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
    {
        <a class="rounded-md border px-3 py-2 text-sm font-medium no-underline @(pageNumber == Model.Page ? "border-slate-900 bg-slate-900 text-white" : "border-slate-300 bg-white text-slate-700 hover:bg-slate-100")" asp-action="Index" asp-route-page="@pageNumber">@pageNumber</a>
    }

    <a class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium no-underline @(Model.HasNextPage ? "bg-white text-slate-700 hover:bg-slate-100" : "pointer-events-none bg-slate-100 text-slate-400")" asp-action="Index" asp-route-page="@(Model.Page + 1)">Siguiente</a>
</nav>
