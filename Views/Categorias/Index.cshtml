@model CrudProductos.Models.ConsultasCategoriasViewModel

@{
    ViewData["Title"] = "Categorias";
}

<div class="mb-6">
    <h1 class="mb-1 text-2xl font-semibold text-slate-950">Nueva tabla: Categorias</h1>
    <p class="m-0 text-sm text-slate-500">Tabla creada con Code First para cargar datos y ejecutar consultas LINQ desde PostgreSQL.</p>
</div>

<form asp-action="Index" method="get" class="mb-8 flex flex-col gap-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm sm:flex-row">
    <input class="min-h-10 flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 outline-none focus:border-slate-500 focus:ring-2 focus:ring-slate-200" type="search" name="busqueda" value="@Model.Busqueda" placeholder="Buscar por nombre o descripcion" />
    <div class="flex gap-2">
        <button class="rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-slate-700" type="submit">Filtrar</button>
        <a class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 no-underline hover:bg-slate-100" asp-action="Index">Limpiar</a>
    </div>
</form>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Todas las categorias</h2>
    @await Html.PartialAsync("_TablaCategorias", Model.Todas)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Categorias activas ordenadas por nombre</h2>
    @await Html.PartialAsync("_TablaCategorias", Model.Activas)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Resultado del filtro</h2>
    @await Html.PartialAsync("_TablaCategorias", Model.Filtradas)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Ultimas 3 categorias creadas</h2>
    @await Html.PartialAsync("_TablaCategorias", Model.Recientes)
</section>
