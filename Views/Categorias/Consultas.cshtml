@model CrudProductos.Models.ConsultasCategoriasViewModel

@{
    ViewData["Title"] = "Categorias";
}

<div class="mb-6">
    <h1 class="mb-1 text-2xl font-semibold text-slate-950">Nueva tabla: Categorias</h1>
    <p class="m-0 text-sm text-slate-500">Tabla creada con Code First para cargar datos y ejecutar consultas LINQ desde PostgreSQL.</p>
    <a class="mt-3 inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 no-underline hover:bg-slate-100" asp-action="Index">Volver al CRUD</a>
</div>

<form asp-action="Consultas" method="get" class="mb-8 flex flex-col gap-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm sm:flex-row">
    <input class="min-h-10 flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 outline-none focus:border-slate-500 focus:ring-2 focus:ring-slate-200" type="search" name="busqueda" value="@Model.Busqueda" placeholder="Buscar por nombre o descripcion" />
    <div class="flex gap-2">
        <button class="rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-slate-700" type="submit">Filtrar</button>
        <a class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 no-underline hover:bg-slate-100" asp-action="Consultas">Limpiar</a>
    </div>
</form>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Where</h2>
    <p class="mb-3 text-sm text-slate-500">LINQ aplicado: <code>Where(c => c.Activa)</code></p>
    @await Html.PartialAsync("_TablaCategorias", Model.Where)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">OrderBy</h2>
    <p class="mb-3 text-sm text-slate-500">LINQ aplicado: <code>OrderBy(c => c.Id)</code></p>
    @await Html.PartialAsync("_TablaCategorias", Model.OrderBy)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">OrderByDescending</h2>
    <p class="mb-3 text-sm text-slate-500">LINQ aplicado: <code>OrderByDescending(c => c.FechaCreacion)</code></p>
    @await Html.PartialAsync("_TablaCategorias", Model.OrderByDescending)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Take</h2>
    <p class="mb-3 text-sm text-slate-500">LINQ aplicado: <code>Take(3)</code></p>
    @await Html.PartialAsync("_TablaCategorias", Model.Take)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Contains</h2>
    <p class="mb-3 text-sm text-slate-500">LINQ aplicado: <code>Where(c => c.Nombre.Contains(textoBusqueda) || c.Descripcion.Contains(textoBusqueda))</code></p>
    @await Html.PartialAsync("_TablaCategorias", Model.Contains)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">ILike o busqueda equivalente en PostgreSQL</h2>
    <p class="mb-3 text-sm text-slate-500">PostgreSQL aplicado desde EF Core: <code>EF.Functions.ILike(c.Nombre, $"%{textoBusqueda}%")</code></p>
    @await Html.PartialAsync("_TablaCategorias", Model.ILike)
</section>

<section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Filtro combinado usando mas de una condicion</h2>
    <p class="mb-3 text-sm text-slate-500">LINQ aplicado: <code>Where(c => c.Activa && c.DescuentoPorcentaje > 5 && EF.Functions.ILike(...))</code></p>
    @await Html.PartialAsync("_TablaCategorias", Model.FiltroCombinado)
</section>
